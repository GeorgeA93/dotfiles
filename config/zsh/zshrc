# ─── Core Settings ────────────────────────────────────────────────
export ZSH=$HOME/.oh-my-zsh
export DOTFILES=$HOME/dotfiles
export EDITOR='vim'
export MESA_LOADER_DRIVER_OVERRIDE=i965
export MGFXC_WINE_PATH=$HOME/.winemonogame
ZSH_THEME="refined"
KEYTIMEOUT=1

# ─── PATH (single assignment, no repeated exports) ───────────────
export PATH="\
/usr/local/bin:\
/usr/bin:\
/bin:\
/usr/sbin:\
/sbin:\
/usr/local/sbin:\
$HOME/.local/bin:\
$DOTFILES/bin:\
$HOME/Dev/flutter/bin:\
/usr/local/opt/mysql@8.0/bin:\
/usr/local/share/dotnet:\
$HOME/.yarn/bin:\
$HOME/.rbenv/shims:\
$HOME/.rbenv/bin"

# ─── Aliases ─────────────────────────────────────────────────────
source ~/.aliases

# ─── Oh My Zsh ───────────────────────────────────────────────────
# Disable automatic updates during shell load (run manually with `omz update`)
DISABLE_AUTO_UPDATE="true"
# If you don't use many plugins, list only what you need:
# plugins=(git)
source $ZSH/oh-my-zsh.sh

# ─── rbenv (lazy) ────────────────────────────────────────────────
# Shims are already on PATH above; this lazy-loads the full init
# only when you run `rbenv` directly (e.g. `rbenv install`)
rbenv() {
  unset -f rbenv
  eval "$(command rbenv init -)"
  rbenv "$@"
}

# ─── NVM (lazy) ──────────────────────────────────────────────────
export NVM_DIR="$HOME/.nvm"

_load_nvm() {
  unset -f nvm node npm npx yarn
  [ -s "/usr/local/opt/nvm/nvm.sh" ] && . "/usr/local/opt/nvm/nvm.sh"
  [ -s "/usr/local/opt/nvm/etc/bash_completion" ] && . "/usr/local/opt/nvm/etc/bash_completion"
}

nvm()  { _load_nvm && nvm  "$@"; }
node() { _load_nvm && node "$@"; }
npm()  { _load_nvm && npm  "$@"; }
npx()  { _load_nvm && npx  "$@"; }
yarn() { _load_nvm && yarn "$@"; }

# ─── FZF ─────────────────────────────────────────────────────────
export FZF_DEFAULT_COMMAND='ag --hidden --ignore .git -f -u -g ""'
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

